# ----------------------------------------------------------------
# Kova Sun Shade — Apache config for the production bundle.
#
# This file ships inside `dist/` after `npm run build`, so dropping
# the whole dist into the web root is enough — no separate server
# config edits required.
# ----------------------------------------------------------------

# --- SPA fallback ------------------------------------------------
# React Router handles /bidai, /roller, /process, /configurator, /blog,
# /bidai/jurnal/<slug>, etc. on the client. Without this rewrite Apache
# returns 404 because no physical /roller directory exists.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for an actual file or directory, serve it.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise hand control to index.html so React Router can route.
  RewriteRule ^ index.html [L]
</IfModule>

# --- Compression -------------------------------------------------
# Mostly redundant with the gzip-pre-compressed bundles Vite emits,
# but covers anything served raw (HTML, sitemaps, manifest, etc.).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml image/svg+xml
  AddOutputFilterByType DEFLATE application/manifest+json
</IfModule>

# --- Cache headers -----------------------------------------------
# Vite's hashed asset filenames are immutable; cache aggressively.
# index.html / robots.txt / sitemap.xml / llms.txt change with every
# deploy, so cache them only briefly so users see updates fast.
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed assets — forever.
  ExpiresByType image/webp           "access plus 1 year"
  ExpiresByType image/jpeg           "access plus 1 year"
  ExpiresByType image/png            "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 year"
  ExpiresByType image/x-icon         "access plus 1 year"
  ExpiresByType video/mp4            "access plus 1 year"
  ExpiresByType font/woff2           "access plus 1 year"
  ExpiresByType text/css             "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Rotates per deploy — cache for 5 minutes.
  ExpiresByType text/html            "access plus 5 minutes"
  ExpiresByType application/xml      "access plus 5 minutes"
  ExpiresByType text/plain           "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
  # Mark every immutable asset with the long-cache hint browsers respect.
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|woff2|mp4|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Short cache for the HTML shell + crawler files.
  <FilesMatch "\.(html|xml|txt)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  # Security baseline.
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- MIME types for fonts + WebP --------------------------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType application/manifest+json .webmanifest
</IfModule>

# --- Prevent listing directories --------------------------------
Options -Indexes

# --- Custom error fallback --------------------------------------
ErrorDocument 404 /index.html
